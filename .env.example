# ──────────────────────────────────────────────
# FinSight AI — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database (PostgreSQL) ──
# Local: postgresql+asyncpg://finsight:finsight_dev@localhost:5432/finsight_db
# Railway: auto-set by PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://finsight:finsight_dev@localhost:5432/finsight_db

# ── Vector Store (Qdrant) ──
# Local: http://localhost:6333
# Production: use Qdrant Cloud URL + API key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Cache (Redis) ──
# Local: redis://localhost:6379/0
# Railway: auto-set by Redis plugin
REDIS_URL=redis://localhost:6379/0

# ── LLM (Google Gemini) ──
# Get your free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Embeddings ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Cache TTL (seconds, default 24 hours) ──
CACHE_TTL=86400

# ── CORS ──
# Local: ["http://localhost:3000","http://127.0.0.1:3000"]
# Production: ["https://your-app.vercel.app"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── App ──
APP_ENV=development
LOG_LEVEL=INFO

# ── Frontend (set in Vercel) ──
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
